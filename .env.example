# Canopy — Environment Variables
#
# Copy this file to .env and fill in your values.
# The canopyd binary reads these from the environment.

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=canopy
DB_PASSWORD=canopy
DB_NAME=canopy
DB_SSLMODE=disable

# HTTP Server
HTTP_ADDR=:8080

# Logging
LOG_LEVEL=info
